            <!-- BEGIN: NEW rule for <directory_path_name>                              -->
            <!-- CCB-68 and CCB-70                                                      -->
            <!--  '([a-zA-Z0-9](([-_a-zA-Z0-9]*[a-zA-Z0-9])|)/)+'                       -->
            <!--                                                                        --> 
            <!--   Minimal combined regression set                                      -->
            <!--        Valid cases                                                     -->
            <!--           1. meca_rdr_sis_files/                                       -->
            <!--                baseline valid single-segment path                      -->
            <!--           2. meca_rdr_sis_files/test/                                  -->
            <!--                baseline valid multi-segment path                       -->
            <!--           3. a/                                                        -->
            <!--                valid minimum-length segment                            -->
            <!--           4. ab-cd/ef_gh/                                              -->
            <!--                valid internal - and _ across multiple segments         -->
            <!--        Invalid cases carried forward from prior set                    -->
            <!--           5. #meca.rdr_sis/                                            -->
            <!--                illegal character at start and illegal .                -->
            <!--           6. /test/meca_rdr_sis_files/                                 -->
            <!--                must not begin with /                                   -->
            <!--           7. meca_rdr_sis_files                                        -->
            <!--                must end with /                                         -->
            <!--           8. ./meca_rdr_sis_files/                                     -->
            <!--                must not contain leading relative segment ./            -->
            <!--           9. ../test/meca_rdr_sis_files/                               -->
            <!--                must not contain parent-relative segment ../            -->
            <!--           10. abc//def/                                                -->
            <!--                empty segment / double slash not allowed                -->
            <!--        Invalid cases added for the new pattern                         -->
            <!--           11. abc-/                                                    -->
            <!--                 segment must not end with -                            -->
            <!--           12. abc_/                                                    -->
            <!--                 segment must not end with _                            -->
            <!--           13. abc/-def/                                                -->
            <!--                 later segment must begin with alphanumeric             -->
            <!--           14. abc/_def/                                                -->
            <!--                 later segment must begin with alphanumeric             -->
            <!--                                                                        -->
            <!--  That set will expose nearly all meaningful behavioral change.         -->
            <!-- ====================================================================== -->         
